{
  "envId": "replace-with-your-cloudbase-env-id",
  "functionRoot": "cloudfunctions",
  "functions": [
    {
      "name": "wanwanApi",
      "handler": "index.main",
      "runtime": "Nodejs18.15",
      "timeout": 60,
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "SETUP_KEY": "replace-with-a-temporary-setup-key"
      },
      "ignore": [
        "node_modules/**",
        ".git/**"
      ]
    }
  ]
}
