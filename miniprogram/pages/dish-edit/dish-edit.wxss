.form {
  padding: 32rpx;
}

.product-head {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.fake-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  position: relative;
  overflow: hidden;
  background: radial-gradient(circle at 72% 24%, #d88935, transparent 22%), linear-gradient(135deg, #7a2a1b, #5c2118);
  box-shadow: inset 0 0 0 2rpx rgba(185, 71, 36, 0.2);
}

.fake-img view {
  position: absolute;
  left: 28rpx;
  top: 38rpx;
  width: 76rpx;
  height: 50rpx;
  border-radius: 50%;
  background: rgba(255, 222, 185, 0.92);
}

.fake-img text {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
}

.dish-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.product-name {
  color: var(--color-ink);
  font-size: 28rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.hint {
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 32rpx;
}

.two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.tags {
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.ok {
  color: #ffffff;
  background: var(--color-ok);
}

.picker-input {
  justify-content: flex-start;
}

.save-btn {
  margin-top: 32rpx;
}
