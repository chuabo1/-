<view class="page">
  <view class="brand-head" style="{{brandHeadStyle}}">
    <image class="brand-logo-image" src="/assets/brand/wanwan-logo.svg" mode="aspectFit" />
    <view class="brand-subtitle">手机工作台 · 仅店员使用</view>
  </view>
  <view class="form">
    <view class="page-title">店员登录</view>
    <view class="hint">通过长按顾客端 Logo 进入</view>
    <view class="field-label">手机号</view>
    <input class="input" value="{{phone}}" placeholder="请输入手机号" bindinput="onPhoneInput" />
    <view class="field-label">密码</view>
    <input class="input" value="{{password}}" password placeholder="请输入密码" bindinput="onPasswordInput" />
    <button class="primary-btn login-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="login">登录工作台</button>
  </view>
</view>
