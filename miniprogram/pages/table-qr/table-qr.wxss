.content {
  padding: 32rpx;
}

.qr-card,
.action-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.qr-title,
.action-title {
  color: var(--color-ink);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 600;
}

.qr {
  width: 272rpx;
  height: 272rpx;
  margin: 32rpx auto;
  border: 16rpx solid #ffffff;
  background: repeating-linear-gradient(45deg, #2a2522 0 16rpx, #ffffff 16rpx 32rpx);
  box-shadow: var(--shadow-small);
  display: flex;
  align-items: center;
  justify-content: center;
}

.qr-image {
  width: 272rpx;
  height: 272rpx;
  margin: 32rpx auto;
  display: block;
}

.qr view {
  width: 96rpx;
  height: 96rpx;
  border: 16rpx solid #2a2522;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  background: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
}

.hint {
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 32rpx;
}

.actions {
  margin-top: 32rpx;
  display: flex;
  gap: 16rpx;
}

.actions .primary-btn {
  flex: 1;
  min-height: 80rpx;
}

.notice {
  padding: 16rpx 32rpx;
  border: 1rpx solid rgba(217, 130, 43, 0.3);
  border-radius: 16rpx;
  color: var(--color-primary);
  background: #fff5e6;
  font-size: 20rpx;
  line-height: 32rpx;
}
