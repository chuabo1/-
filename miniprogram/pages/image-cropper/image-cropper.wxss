.crop-page {
  min-height: 100vh;
  background: #111111;
  color: #ffffff;
  overflow: hidden;
}

.crop-head {
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 24rpx;
  background: #1f1f1f;
}

.crop-title {
  font-size: 34rpx;
  line-height: 48rpx;
  font-weight: 600;
}

.crop-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 34rpx;
}

.crop-stage {
  position: relative;
  width: 100vw;
  overflow: hidden;
  background: #000000;
}

.move-image {
  position: absolute;
}

.source-image {
  width: 100%;
  height: 100%;
  display: block;
}

.shade {
  position: absolute;
  background: rgba(0, 0, 0, 0.54);
  pointer-events: none;
}

.top {
  left: 0;
  right: 0;
  top: 0;
}

.bottom {
  left: 0;
  right: 0;
  bottom: 0;
}

.left {
  left: 0;
}

.right {
  right: 0;
}

.crop-box {
  position: absolute;
  border: 4rpx solid #ffffff;
  box-shadow: 0 0 0 1rpx rgba(185, 71, 36, 0.8);
  pointer-events: none;
}

.crop-controls {
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  color: var(--color-ink);
}

.zoom-row {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 72rpx;
  gap: 16rpx;
  align-items: center;
  color: var(--color-muted);
  font-size: 22rpx;
}

.crop-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: 160rpx minmax(0, 1fr);
  gap: 16rpx;
}

.cancel-btn {
  min-height: 80rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  background: #f3f3f3;
  font-size: 26rpx;
}

.confirm-btn {
  min-height: 80rpx;
}

.crop-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}
