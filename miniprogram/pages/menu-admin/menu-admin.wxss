.content {
  padding: 32rpx;
}

.count {
  color: var(--color-primary);
  font-size: 24rpx;
}

.dish-admin-row {
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 224rpx;
  gap: 12rpx;
  align-items: center;
}

.dish-admin-info {
  min-width: 0;
  overflow: hidden;
}

.dish-admin-name {
  color: var(--color-ink);
  font-size: 28rpx;
  line-height: 40rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-admin-sub {
  margin-top: 4rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 32rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-admin-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8rpx;
}

.small-btn {
  width: 68rpx;
  min-height: 56rpx;
  padding: 0;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  background: var(--color-tag);
  font-size: 22rpx;
}
