.menu-page {
  height: 100vh;
  padding-bottom: calc(144rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.menu-head {
  flex: 0 0 auto;
  min-height: 240rpx;
  padding: calc(env(safe-area-inset-top) + 24rpx) 32rpx 32rpx;
  color: #ffffff;
  background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
  background-size: cover;
  background-position: center;
}

.brand-safe {
  max-width: calc(100% - 216rpx);
}

.brand-row {
  display: flex;
  align-items: center;
}

.logo-badge {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 14rpx;
  line-height: 18rpx;
  transform: rotate(-12deg);
}

.brand-word {
  font-size: 44rpx;
  line-height: 64rpx;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.head-meta {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #ffe3d5;
  font-size: 20rpx;
  line-height: 32rpx;
  white-space: nowrap;
  overflow: hidden;
}

.head-meta text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.table-pill {
  padding: 8rpx 16rpx;
  border-radius: var(--radius-pill);
  color: #ffffff;
  background: #2a2522;
  font-weight: 600;
}

.menu-layout {
  flex: 1;
  min-height: 0;
  display: flex;
}

.category-list {
  width: 144rpx;
  padding-top: 24rpx;
  background: #ffffff;
}

.cat-item {
  min-height: 128rpx;
  width: 144rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-muted);
  text-align: center;
  font-size: 26rpx;
  line-height: 40rpx;
  white-space: pre-line;
}

.cat-item.active {
  color: var(--color-primary);
  background: var(--color-warm);
}

.cat-item.active::before {
  content: "";
  position: absolute;
  left: 0;
  top: 32rpx;
  width: 8rpx;
  height: 64rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
}

.cat-dot {
  position: absolute;
  right: 0;
  top: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--color-accent);
  font-size: 18rpx;
  font-weight: 700;
}

.dish-list {
  flex: 1;
  height: 100%;
  padding: 32rpx 16rpx 0;
}

.section-title {
  margin-bottom: 32rpx;
  padding-left: 16rpx;
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: var(--color-ink);
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  width: 8rpx;
  height: 32rpx;
  border-radius: var(--radius-pill);
  background: var(--color-primary);
}

.section-title-text {
  line-height: 44rpx;
}

.hot-badge {
  min-height: 36rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--color-accent);
  font-size: 18rpx;
  line-height: 28rpx;
}

.spec-quantity-row {
  min-height: 96rpx;
  margin-top: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.spec-quantity-label {
  margin: 0;
}

.spec-quantity-row .stepper {
  flex: 0 0 auto;
}

.spec-stepper {
  width: 176rpx;
  height: 64rpx;
  flex: 0 0 auto;
}

.sheet-cart {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-cart .stepper {
  justify-content: flex-start;
}

.sheet-cart .primary-btn {
  min-width: 232rpx;
  flex: 0 0 auto;
}

.sheet-price {
  color: var(--color-ink);
  font-size: 36rpx;
  line-height: 44rpx;
}

.sheet-sub {
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 36rpx;
}

.confirm-actions {
  display: flex;
}

.confirm-actions .primary-btn {
  width: 100%;
}

.cart-clear-head {
  min-height: 56rpx;
  padding: 0 4rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 30rpx;
}

.trash-icon {
  width: 24rpx;
  height: 24rpx;
  position: relative;
  flex: 0 0 auto;
}

.trash-lid {
  position: absolute;
  left: 3rpx;
  top: 2rpx;
  width: 18rpx;
  height: 3rpx;
  border-radius: 4rpx;
  background: var(--color-muted);
}

.trash-lid::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: -4rpx;
  width: 6rpx;
  height: 4rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: var(--color-muted);
}

.trash-body {
  position: absolute;
  left: 5rpx;
  top: 7rpx;
  width: 14rpx;
  height: 16rpx;
  border: 2rpx solid var(--color-muted);
  border-top: 0;
  border-radius: 0 0 5rpx 5rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.trash-line {
  width: 2rpx;
  height: 10rpx;
  border-radius: 2rpx;
  background: var(--color-muted);
}

.cart-drawer-footer {
  min-height: 120rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 232rpx;
  gap: 24rpx;
  align-items: center;
}

.cart-items {
  padding-bottom: 0;
}

.cart-items-tail {
  height: 0;
}

.cart-drawer-footer .confirm-total {
  text-align: right;
  font-size: 32rpx;
  line-height: 42rpx;
  white-space: nowrap;
}

.cart-drawer-footer .primary-btn {
  min-height: 84rpx;
  padding: 0 40rpx;
  min-width: 0;
  border-radius: var(--radius-pill);
  font-size: 28rpx;
}

.confirm-card {
  padding: 32rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.confirm-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dine-in {
  color: var(--color-ok);
}

.confirm-order-no {
  margin-top: 16rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 32rpx;
  font-weight: 400;
}

.confirm-line {
  min-height: 72rpx;
  border-bottom: 1rpx solid rgba(34, 34, 34, 0.04);
  display: grid;
  grid-template-columns: minmax(0, 1fr) 80rpx 112rpx;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  line-height: 44rpx;
}

.confirm-line text:last-child {
  color: var(--color-accent);
  font-weight: 700;
  text-align: right;
}

.confirm-total {
  color: var(--color-accent);
  text-align: right;
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.confirm-submit {
  min-width: 240rpx;
}

.confirm-bottom {
  min-height: 112rpx;
}
