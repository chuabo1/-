.content {
  padding: 32rpx;
}

.total-card,
.order-block {
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.total-card {
  font-size: 28rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.total-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-head text:nth-child(2) {
  color: var(--color-accent);
  font-size: 36rpx;
}

.total-card view {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  font-weight: 400;
}

.remark {
  margin: 24rpx 0;
  padding: 16rpx 32rpx;
  border: 1rpx solid rgba(217, 130, 43, 0.3);
  border-radius: 16rpx;
  color: var(--color-primary);
  background: #fff5e6;
}

.item-line {
  margin-top: 16rpx;
  color: var(--color-ink);
  font-size: 24rpx;
  line-height: 36rpx;
}
