<view class="page">
  <view class="brand-head" style="{{brandHeadStyle}}">
    <view class="brand-title">同桌订单</view>
    <view class="brand-subtitle">聚合显示同桌多笔加菜单</view>
  </view>
  <view class="content">
    <view class="card total-card">
      <view class="total-head">
        <text>本桌合计</text>
        <text>¥{{total}}</text>
      </view>
      <view>{{orders.length}}笔订单</view>
    </view>
    <view wx:for="{{orders}}" wx:key="_id" class="card order-block">
      <view class="badge">{{item.statusText}}</view>
      <view wx:if="{{item.remark}}" class="remark">备注：{{item.remark}}</view>
      <view wx:for="{{item.items}}" wx:key="dishId" class="item-line">
        {{item.name}} x{{item.quantity}} · ¥{{item.subtotal}}
      </view>
    </view>
    <button class="primary-btn" bindtap="finishAll">全部完成</button>
  </view>
</view>
