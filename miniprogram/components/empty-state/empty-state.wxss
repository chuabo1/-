.state {
  padding: 96rpx 32rpx;
  text-align: center;
}

.state-icon {
  font-size: 48rpx;
  line-height: 64rpx;
}

.state-title {
  margin-top: 16rpx;
  color: var(--color-ink);
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 8rpx;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 36rpx;
}

.state-btn {
  margin: 32rpx auto 0;
  min-width: 192rpx;
  height: 80rpx;
  padding: 0 32rpx;
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: var(--color-primary);
  font-size: 28rpx;
  font-weight: 600;
}
