<view wx:if="{{visible}}" class="sheet-wrap">
  <view class="sheet-mask" bindtap="onClose"></view>
  <view class="sheet safe-bottom" style="{{heightStyle}}">
    <view class="sheet-head">
      <text class="sheet-title">{{title}}</text>
      <button wx:if="{{!headerAction}}" class="sheet-close" bindtap="onClose">{{closeText}}</button>
      <view wx:else class="sheet-action">
        <slot name="header-action"></slot>
      </view>
    </view>
    <scroll-view scroll-y class="sheet-body {{bodyClass}}">
      <slot></slot>
    </scroll-view>
    <view wx:if="{{footer}}" class="sheet-footer">
      <slot name="footer"></slot>
    </view>
  </view>
</view>
