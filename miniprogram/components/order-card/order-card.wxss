.order-card {
  border: 1rpx solid rgba(185, 71, 36, 0.18);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 22rpx rgba(0, 0, 0, 0.08);
}

.order-card.pending {
  border-color: rgba(185, 71, 36, 0.26);
}

.order-card.confirmed {
  border-color: rgba(217, 130, 43, 0.3);
}

.order-card.completed {
  border-color: rgba(18, 131, 75, 0.24);
}

.order-head-row {
  min-height: 64rpx;
  padding-bottom: 16rpx;
  display: grid;
  grid-template-columns: 144rpx minmax(0, 1fr) 144rpx;
  gap: 16rpx;
  align-items: center;
}

.order-section {
  padding-top: 24rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(34, 34, 34, 0.06);
}

.order-table {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: var(--color-ink);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.table-unit {
  font-size: 28rpx;
  line-height: 40rpx;
}

.order-total {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  color: var(--color-accent);
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 700;
}

.order-sub-row {
  display: flex;
  align-items: center;
}

.status-badge {
  flex: 0 0 auto;
  min-width: 128rpx;
}

.order-meta {
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 36rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-remark {
  margin-top: 32rpx;
  padding: 16rpx 32rpx;
  border: 1rpx solid rgba(217, 130, 43, 0.3);
  border-radius: 16rpx;
  color: var(--color-primary);
  background: #fff5e6;
  font-size: 24rpx;
  line-height: 36rpx;
}

.order-items {
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(34, 34, 34, 0.04);
}

.order-item {
  min-height: 40rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 64rpx;
  gap: 16rpx;
  align-items: center;
  color: var(--color-muted);
  font-size: 24rpx;
  line-height: 36rpx;
}

.order-item-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-item-qty {
  text-align: right;
  color: var(--color-ink);
  font-weight: 600;
}

.order-actions {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200rpx, 1fr));
  gap: 16rpx;
}

.action {
  min-height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: none;
  font-size: 26rpx;
  line-height: normal;
}

.order-actions .primary-btn {
  color: #ffffff;
  background: var(--color-primary);
}

.order-actions .secondary-btn {
  border: 1rpx solid rgba(185, 71, 36, 0.24);
  color: var(--color-primary);
  background: var(--color-tag);
}
