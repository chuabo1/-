.dish-row {
  height: 208rpx;
  display: grid;
  grid-template-columns: 160rpx minmax(0, 1fr) 176rpx;
  gap: 16rpx;
  align-items: start;
  padding-bottom: 32rpx;
}

.dish-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-image);
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(70, 20, 0, 0.06), var(--shadow-small);
}

.image-beef { background: radial-gradient(circle at 72% 24%, #d9822b, transparent 22%), linear-gradient(135deg, #6f261a, #5c2118); }
.image-wing { background: radial-gradient(circle at 72% 24%, #d88935, transparent 22%), linear-gradient(135deg, #7a2a1b, #5c2118); }
.image-egg { background: radial-gradient(circle at 72% 24%, #e9a24a, transparent 22%), linear-gradient(135deg, #b85e23, #5c2118); }
.image-snail { background: radial-gradient(circle at 72% 24%, #c76d2e, transparent 22%), linear-gradient(135deg, #542218, #5c2118); }

.plate {
  position: absolute;
  left: 36rpx;
  top: 48rpx;
  width: 96rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 222, 185, 0.92);
}

.dish-img-name {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 32rpx;
  font-weight: 600;
}

.dish-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.dish-info {
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}

.dish-name {
  margin-top: -4rpx;
  color: var(--color-ink);
  font-size: 30rpx;
  line-height: 44rpx;
  font-weight: 700;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.dish-tag {
  margin-top: 16rpx;
  min-height: 32rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(217, 130, 43, 0.32);
  border-radius: var(--radius-pill);
  display: inline-flex;
  align-items: center;
  background: var(--color-tag);
  color: var(--color-primary-dark);
  font-size: 20rpx;
  line-height: 32rpx;
}

.dish-price {
  margin-top: auto;
  color: var(--color-accent);
  font-size: 36rpx;
  line-height: 44rpx;
  font-weight: 700;
}

.dish-unit {
  margin-left: 2rpx;
  color: var(--color-muted);
  font-size: 20rpx;
  line-height: 32rpx;
  font-weight: 400;
}

.dish-action {
  width: 176rpx;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
  overflow: visible;
}

.row-stepper {
  width: 176rpx;
  height: 64rpx;
  flex: 0 0 auto;
}

.tap-plus {
  width: 48rpx;
  height: 48rpx;
  min-height: 48rpx;
  margin-bottom: 0;
  border-radius: 50%;
  position: relative;
  color: #ffffff;
  background: var(--color-primary);
  font-size: 36rpx;
  line-height: 1;
  font-weight: 600;
  box-shadow: var(--shadow-small);
}

.tap-plus-symbol {
  position: absolute;
  left: 50%;
  top: 50%;
  line-height: 1;
  transform: translate(-50%, -52%);
}

.spec-btn {
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: var(--radius-pill);
  color: #ffffff;
  background: #2a2522;
  font-size: 22rpx;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-small);
}

.spec-btn.disabled {
  background: #cccccc;
}
